# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here

# =============================================================================
# DATABASE CONNECTION - Choose ONE option below
# =============================================================================

# OPTION 1: Heroku JAWS DB (production)
# -----------------------------------------------------------------------------
# Heroku automatically sets this when you add the JAWS DB add-on.
# You don't need to set this manually - just run: heroku addons:create jawsdb:kitefin
#
# JAWSDB_URL=mysql://username:password@host:port/database

# OPTION 2: Local Development
# -----------------------------------------------------------------------------
# Use these for local MySQL development
#
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
